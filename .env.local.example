# Google Sheets API Configuration
# 1. Create a Google Cloud project and enable Google Sheets API
# 2. Create API credentials (API Key)
# 3. Share your Google Sheet with view access to anyone with the link
# 4. Copy the Sheet ID from the URL (the long string between /d/ and /edit)

NEXT_PUBLIC_GOOGLE_SHEET_ID=your_sheet_id_here
NEXT_PUBLIC_GOOGLE_API_KEY=your_api_key_here

# Sheet should have columns in this order:
# Titre | Réalisateur | Année | Genre | Durée | Note | Affiche URL | Synopsis | Plateforme | Vu | Date ajout
